<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.scoula.member.mapper.MemberMapper">

    <resultMap id="memberMap" type="org.scoula.member.domain.MemberVO">
        <id     property="no"          column="no"/>
        <result property="username"    column="username"/>
        <result property="password"    column="password"/>
        <result property="email"       column="email"/>
        <result property="birthYear"   column="birth_year"/>
        <result property="regDate"     column="reg_date"/>
        <result property="updatedDate" column="updated_date"/>
    </resultMap>

    <!-- 전체 조회 -->
    <select id="getList" resultMap="memberMap">
        SELECT no, username, password, email, birth_year, reg_date, updated_date
        FROM member
        ORDER BY no DESC
    </select>

    <!-- 단건 조회 -->
    <select id="get" parameterType="long" resultMap="memberMap">
        SELECT no, username, password, email, birth_year, reg_date, updated_date
        FROM member
        WHERE no = #{no}
    </select>

    <!-- 등록 -->
    <insert id="insert" parameterType="org.scoula.member.domain.MemberVO">
        INSERT INTO member (username, password, email, birth_year, reg_date, updated_date)
        VALUES (#{username}, #{password}, #{email}, #{birthYear}, NOW(), NOW())
    </insert>

    <!-- 수정 -->
    <update id="update" parameterType="org.scoula.member.domain.MemberVO">
        UPDATE member
        SET username     = #{username},
            password     = #{password},
            email        = #{email},
            birth_year   = #{birthYear},
            updated_date = NOW()
        WHERE no = #{no}
    </update>

    <!-- 삭제 -->
    <delete id="delete" parameterType="long">
        DELETE FROM member
        WHERE no = #{no}
    </delete>

</mapper>